# ==========================================
# GIVANCE RESTO - CONFIGURAÇÃO DE PRODUÇÃO
# ==========================================

# 1. Aplicação
# URL base do sistema (sem barra no final)
NEXT_PUBLIC_APP_URL=https://givanceresto.com.br
NEXT_PUBLIC_API_URL=https://givanceresto.com.br/api

# 2. Banco de Dados (PostgreSQL)
# Use uma senha forte em produção!
DATABASE_URL="postgresql://postgres:SUA_SENHA_FORTE@db:5432/restogestao?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SUA_SENHA_FORTE
POSTGRES_DB=restogestao

# 3. Autenticação e Segurança
NEXTAUTH_SECRET=GERE_UM_HASH_SEGURO_AQUI_OPENSSL_RAND_BASE64_32
NEXTAUTH_URL=https://givanceresto.com.br

# 4. Configurações de Upload
# Pasta onde as imagens serão salvas dentro do container
UPLOAD_DIR=/app/public/uploads
MAX_FILE_SIZE=5242880 # 5MB em bytes

# 5. Modo de Ambiente
NODE_ENV=production
